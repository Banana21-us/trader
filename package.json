{
  "name": "trader-bot",
  "version": "1.0.0",
  "description": "Claude-powered multi-model trade signal analyzer",
  "type": "module",
  "scripts": {
    "start": "node --env-file=.env src/index.js",
    "watch": "node --env-file=.env src/watch.js",
